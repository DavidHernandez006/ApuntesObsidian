        {"id": "e3", "fromNode": "inscripciones01", "fromSide": "right", "toNode": "grupos01", "toSide": "left", "label": "codigo_materia + semestre"},
        {"id": "e4", "fromNode": "grupos01", "fromSide": "right", "toNode": "materias01", "toSide": "left", "label": "codigo_materia"},
        {"id": "e5", "fromNode": "grupos01", "fromSide": "bottom", "toNode": "profesores01", "toSide": "top", "label": "id_profesor"}
    ]
}
