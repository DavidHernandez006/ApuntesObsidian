{
	"nodes":[
		{"id":"b65cadf92e8ac948","type":"text","text":"DML DATA MANIPULATION LENGUAGE\nSe utiliza para gestionar los datos de una tabla","x":-1136,"y":120,"width":384,"height":60,"color":"2"},
		{"id":"2acfd111a24ff8cb","type":"text","text":"INSERT : Añade registros","x":-1069,"y":260,"width":250,"height":60},
		{"id":"3c0b1bf3905df1c9","type":"text","text":"UPDATE : modifica datos existentes","x":-760,"y":230,"width":250,"height":60},
		{"id":"2239c6a3430b520c","type":"text","text":"```\nUPDATE Usuarios SET nombre = 'Clara' WHERE id = 1;\n```","x":-752,"y":327,"width":250,"height":94},
		{"id":"6df3f51a4c54db6d","type":"text","text":"```\nDELETE FROM Usuarios WHERE id = 1;\n```","x":-1460,"y":380,"width":250,"height":100},
		{"id":"c3608e7e026b3b11","type":"text","text":"DELETE: Elimina registros especificos","x":-1460,"y":230,"width":250,"height":60},
		{"id":"a2savept000000001","type":"text","text":"SAVEPOINT : Crea un punto de referencia dentro de una transacción","x":198,"y":-426,"width":280,"height":80},
		{"id":"005edd83064d4bb3","type":"text","text":"# COMANDO   EN   SQL ","x":-279,"y":-79,"width":359,"height":79,"color":"#e60000"},
		{"id":"8be8fe5f1aedb8ff","type":"text","text":"##### DDL (DATA DEFINITION LENGUAGE)\n##### Se utiliza para alterar una base de datos como: Tablas, vistas o indices.","x":359,"y":106,"width":426,"height":120,"color":"2"},
		{"id":"a1renam0000000001","type":"text","text":"RENAME : Cambia el nombre de un objeto","x":862,"y":466,"width":285,"height":60},
		{"id":"a1renam0000000002","type":"text","text":"```\nRENAME TABLE usuarios TO clientes;\n```","x":862,"y":546,"width":285,"height":107},
		{"id":"8563d4137651e7f8","type":"text","text":"```\nSELECT nombre, email FROM Usuarios WHERE id > 5;\n```","x":-950,"y":-479,"width":250,"height":60},
		{"id":"7f21c07785d2343a","type":"text","text":"SELECT: Recoge datos que el usuario pida","x":-950,"y":-360,"width":250,"height":60},
		{"id":"85effb3544dafb64","type":"text","text":"DQL (DATA QUERY LENGUGAE) - Consulta\nSe encarga de traer, obtener recuperar informacion de la base de datos ","x":-1015,"y":-240,"width":380,"height":102,"color":"2"},
		{"id":"96483427f1c52d39","type":"text","text":"DCL (DATA CONTROL LENGUAGE)\nSe encarga de la seguirdad y los permisos de los usuarios del sistema ","x":718,"y":-355,"width":384,"height":111,"color":"2"},
		{"id":"ec045f700110a684","type":"text","text":"REVOKE :Retira los permisos previamente concedidos.","x":1168,"y":-244,"width":272,"height":74},
		{"id":"af0602c43121548a","type":"text","text":"```\nREVOKE INSERT ON Usuarios FROM usuario_invitado;\n```","x":1185,"y":-111,"width":406,"height":125},
		{"id":"49f2d181ee6cd123","type":"text","text":"GRANT : Otorga permisos de acceso a un usuario","x":785,"y":-220,"width":250,"height":50},
		{"id":"a2savept000000002","type":"text","text":"```\nSAVEPOINT antes_de_borrar;\n```","x":429,"y":-554,"width":280,"height":50},
		{"id":"74f4f68f327f60b4","type":"text","text":"```\nGRANT SELECT, INSERT ON Usuarios TO usuario_invitado;\n```","x":785,"y":-111,"width":250,"height":125},
		{"id":"a1trunc0000000002","type":"text","text":"```\nTRUNCATE TABLE usuarios;\n```","x":384,"y":700,"width":343,"height":54},
		{"id":"a1trunc0000000001","type":"text","text":"TRUNCATE : Elimina todos los registros sin borrar la estructura","x":388,"y":593,"width":343,"height":60},
