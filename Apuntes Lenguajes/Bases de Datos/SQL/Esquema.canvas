		{"id":"a2tclhd0000000001","type":"text","text":"TCL (TRANSACTION CONTROL LENGUAGE)\nSe encarga de gestionar las transacciones, garantizando consistencia en los cambios.","x":-249,"y":-244,"width":300,"height":100,"color":"2"},
